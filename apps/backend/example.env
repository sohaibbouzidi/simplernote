APP_NAME=simplernote
ENVIRONMENT=development
DEBUG=True

DATABASE_URL=
REDIS_URL=

JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# Optional service toggles
ENABLE_PG_VECTOR=False
# Sentry
SENTRY_DSN=

# SMTP (Gmail)
# For Gmail: use smtp.gmail.com, port 587, and an App Password (not your regular password)
# Generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_FROM_NAME=Simplernote

# Public-facing URL for email links
BASE_URL=http://localhost:3000

# Timezone (default UTC, e.g. America/New_York)
TIMEZONE=UTC


S3_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=simplernote
S3_REGION=us-east-1
S3_USE_SSL=false